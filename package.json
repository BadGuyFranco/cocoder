{
  "name": "cocoder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json && pnpm -r typecheck",
    "test": "pnpm -r test",
    "build:ui": "pnpm --filter @cocoder/ui build",
    "check:topology": "node scripts/check-topology.mjs",
    "proof:oz-awareness": "node scripts/proof-oz-awareness.mjs",
    "proof:queue": "node scripts/proof-priorities-queue.mjs",
    "proof:run-dir-migration": "node scripts/proof-run-dir-migration.mjs",
    "proof:workspace-segmentation": "node scripts/proof-workspace-segmentation.mjs"
  },
  "devDependencies": {
    "@cocoder/cli": "workspace:*",
    "@types/node": "^24.0.0",
    "eslint": "9.39.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.62.0",
    "vitest": "^3.1.4"
  }
}
