{
  "contract": "adapter-declaration",
  "version": 1,
  "status": "phase-2-draft",
  "description": "Declares a model, CLI, script, or future execution backend and the capabilities routes may depend on.",
  "required": [
    "id",
    "label",
    "kind",
    "command",
    "availabilityCheck",
    "capabilities",
    "writeCapability",
    "sandboxModes",
    "approvalModes",
    "resultContract",
    "evidenceCapabilities",
    "failureModes"
  ],
  "fields": {
    "id": { "type": "string", "pattern": "kebab-case stable identifier" },
    "label": { "type": "string" },
    "kind": { "enum": ["llm-cli", "script", "future-cli", "manual-ingest"] },
    "command": { "type": "string", "description": "Default command or script entry point." },
    "commandEnv": { "type": "string", "optional": true },
    "availabilityCheck": { "type": "object", "required": ["commandExists"], "optional": ["versionCommand", "authHint"] },
    "capabilities": {
      "type": "object",
      "required": [
        "interactive",
        "initialPrompt",
        "stdinDispatch",
        "resultFile",
        "transcriptCapture",
        "streamingDetection",
        "screenshots",
        "dom",
        "console",
        "shell",
        "fileEdit"
      ]
    },
    "writeCapability": { "enum": ["none", "bounded", "repo"] },
    "sandboxModes": { "type": "array", "items": "string" },
    "approvalModes": { "type": "array", "items": "string" },
    "resultContract": { "type": "string" },
    "evidenceCapabilities": { "type": "array", "items": "transcript|screenshot|dom|console|command-output|diff|test-result|human-confirmation" },
    "failureModes": { "type": "array", "items": "missing-cli|auth-expired|stalled-tui|refusal|no-result-file|permission-prompt|rate-limit|unknown" }
  },
  "rules": [
    "Adapters do not imply persona identity.",
    "Routes may require capabilities; launch fails before session start if an assigned adapter lacks them.",
    "Read-only verifier routes must reject adapters with write capability unless the route explicitly disables writes.",
    "Future CLI adapters remain unavailable until availability and result ingestion are proven."
  ]
}
