{
  "id": "cursor-agent",
  "label": "Cursor CLI",
  "kind": "llm-cli",
  "command": "cursor-agent",
  "commandEnv": "inherit",
  "availabilityCheck": {
    "commandExists": "cursor-agent",
    "versionCommand": "cursor-agent --version",
    "authHint": "Run `cursor-agent login` (or set CURSOR_API_KEY) and confirm `cursor-agent status` reports a logged-in account if preflight reports auth/config unavailable."
  },
  "capabilities": {
    "interactive": true,
    "initialPrompt": true,
    "stdinDispatch": true,
    "resultFile": true,
    "transcriptCapture": true,
    "streamingDetection": true,
    "screenshots": false,
    "dom": false,
    "console": false,
    "shell": true,
    "fileEdit": true
  },
  "writeCapability": "repo",
  "sandboxModes": ["read-only", "workspace-write", "danger-full-access"],
  "approvalModes": ["never", "on-request"],
  "resultContract": "job-result",
  "evidenceCapabilities": ["transcript", "command-output", "diff", "test-result"],
  "failureModes": ["missing-cli", "auth-expired", "stalled-tui", "refusal", "no-result-file", "permission-prompt", "rate-limit", "unknown"]
}
