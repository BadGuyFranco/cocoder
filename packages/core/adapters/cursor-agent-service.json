{
  "id": "cursor-agent-service",
  "label": "Cursor Agent (headless orchestration service executor)",
  "kind": "llm-cli",
  "command": "cursor-agent",
  "commandEnv": "inherit",
  "availabilityCheck": {
    "commandExists": "cursor-agent",
    "versionCommand": "cursor-agent --version",
    "authHint": "Install Cursor Agent and complete local authentication (`cursor-agent login` or CURSOR_API_KEY) before assigning it to headless orchestration services."
  },
  "capabilities": {
    "interactive": false,
    "initialPrompt": true,
    "stdinDispatch": false,
    "resultFile": true,
    "transcriptCapture": true,
    "streamingDetection": false,
    "screenshots": false,
    "dom": false,
    "console": false,
    "shell": true,
    "fileEdit": true
  },
  "writeCapability": "repo",
  "sandboxModes": ["danger-full-access"],
  "approvalModes": ["never"],
  "resultContract": "orchestration-service-packet",
  "evidenceCapabilities": ["transcript", "command-output", "diff", "test-result"],
  "failureModes": ["missing-cli", "auth-expired", "refusal", "no-result-file", "permission-prompt", "rate-limit", "unknown"]
}
