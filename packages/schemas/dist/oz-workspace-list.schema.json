{
  "$ref": "#/definitions/cocoder-oz-workspace-list",
  "definitions": {
    "cocoder-oz-workspace-list": {
      "type": "object",
      "properties": {
        "workspaces": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "pattern": "^(\\$\\{COCODER_HOME\\}|\\$\\{root:[A-Za-z0-9_-]+\\}|\\/|~)"
              },
              "tmuxSocket": {
                "type": "string",
                "minLength": 1
              },
              "lastSeenAt": {
                "type": "string",
                "format": "date-time"
              },
              "resolvedPath": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "id",
              "path",
              "resolvedPath"
            ],
            "additionalProperties": true
          }
        }
      },
      "required": [
        "workspaces"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
