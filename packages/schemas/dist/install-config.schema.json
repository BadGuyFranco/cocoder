{
  "$ref": "#/definitions/cocoder-install-config",
  "definitions": {
    "cocoder-install-config": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "default": "0.1"
        },
        "defaults": {
          "type": "object",
          "properties": {
            "adapter": {
              "type": "string",
              "minLength": 1
            },
            "profile": {
              "type": "string",
              "minLength": 1
            },
            "route": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "adapters": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "command": {
                "type": "string",
                "minLength": 1
              },
              "account": {
                "type": "string",
                "minLength": 1
              },
              "enabled": {
                "type": "boolean"
              }
            },
            "required": [
              "id"
            ],
            "additionalProperties": true
          }
        },
        "modelRoles": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "oz": {
          "type": "object",
          "properties": {
            "host": {
              "type": "string",
              "const": "127.0.0.1",
              "default": "127.0.0.1"
            },
            "port": {
              "type": "integer",
              "minimum": 1024,
              "maximum": 65535,
              "default": 7878
            }
          },
          "additionalProperties": true
        },
        "theme": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "system",
                "light",
                "dark"
              ],
              "default": "system"
            },
            "accent": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "secrets": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^\\$\\{(env:[A-Z0-9_]+|file:[^}]+|keychain:[^/}]+\\/[^}]+)\\}$"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
