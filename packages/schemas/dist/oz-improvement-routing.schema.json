{
  "$ref": "#/definitions/cocoder-oz-improvement-routing",
  "definitions": {
    "cocoder-oz-improvement-routing": {
      "type": "object",
      "properties": {
        "target": {
          "type": "string",
          "enum": [
            "cocoder-product",
            "workspace-shared",
            "workspace-local",
            "install-local",
            "upstream-candidate"
          ]
        },
        "generality": {
          "type": "string",
          "enum": [
            "local-only",
            "workspace-specific",
            "generalizable"
          ]
        },
        "workspaceId": {
          "type": "string",
          "minLength": 1
        },
        "developerModeRequired": {
          "type": "boolean",
          "default": false
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "proposedPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "required": [
        "target",
        "generality",
        "rationale"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
