{
  "$ref": "#/definitions/cocoder-oz-workspace-priority-list",
  "definitions": {
    "cocoder-oz-workspace-priority-list": {
      "type": "object",
      "properties": {
        "workspaceId": {
          "type": "string",
          "minLength": 1
        },
        "prioritiesPath": {
          "type": "string",
          "minLength": 1
        },
        "priorities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "slug": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "section": {
                "type": "string",
                "enum": [
                  "Active",
                  "Draft"
                ]
              },
              "readmePath": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "slug",
              "description",
              "status",
              "section",
              "readmePath"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "workspaceId",
        "prioritiesPath",
        "priorities"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
