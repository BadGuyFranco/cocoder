{
  "$ref": "#/definitions/cocoder-workspaces-registry",
  "definitions": {
    "cocoder-workspaces-registry": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "default": "0.1"
        },
        "workspaces": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "pattern": "^(\\$\\{COCODER_HOME\\}|\\$\\{root:[A-Za-z0-9_-]+\\}|\\/|~)"
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "tmuxSocket": {
                "type": "string",
                "minLength": 1
              },
              "lastSeenAt": {
                "type": "string",
                "format": "date-time"
              }
            },
            "required": [
              "id",
              "path"
            ],
            "additionalProperties": true
          },
          "default": []
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
