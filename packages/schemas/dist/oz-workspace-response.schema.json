{
  "$ref": "#/definitions/cocoder-oz-workspace-response",
  "definitions": {
    "cocoder-oz-workspace-response": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "pattern": "^(\\$\\{COCODER_HOME\\}|\\$\\{root:[A-Za-z0-9_-]+\\}|\\/|~)"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tmuxSocket": {
          "type": "string",
          "minLength": 1
        },
        "lastSeenAt": {
          "type": "string",
          "format": "date-time"
        },
        "resolvedPath": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "path",
        "resolvedPath"
      ],
      "additionalProperties": true
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
