    "oz-dashboard": "workspace:*",
    "schemas": "workspace:*",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
